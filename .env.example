# PromptFight — environment variables
# Copy this file to .env and fill in the values you need.
# The tool works without any API keys (mock mode is used automatically).

# ---------------------------------------------------------------------------
# API Keys (optional — tool works in mock mode without them)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=           # Your OpenAI API key (sk-...)
ANTHROPIC_API_KEY=        # Your Anthropic API key (sk-ant-...)

# ---------------------------------------------------------------------------
# Default behaviour overrides (all optional)
# ---------------------------------------------------------------------------
PROMPTFIGHT_MODELS=mock           # Comma-separated list of models to test against.
                                  # Examples: gpt-4o-mini,claude-3-haiku-20240307
                                  # Use "mock" for offline testing.

PROMPTFIGHT_RUNS=3                # Number of trials per prompt per model.

PROMPTFIGHT_FORMAT=table          # Output format: table | json | csv

PROMPTFIGHT_MAX_TOKENS=512        # Max tokens per LLM response.

PROMPTFIGHT_JUDGE_MODEL=          # Optional LLM judge model (e.g. gpt-4o-mini).
                                  # Leave blank to use the built-in heuristic judge.

# ---------------------------------------------------------------------------
# API base URLs (override for proxies / local models)
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_VERSION=2023-06-01

# ---------------------------------------------------------------------------
# Demo convenience — preferred model when key is present
# ---------------------------------------------------------------------------
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ---------------------------------------------------------------------------
# Per-model cost overrides (USD per 1 000 tokens, input+output combined)
# ---------------------------------------------------------------------------
COST_GPT4O=0.005
COST_GPT4O_MINI=0.00015
COST_GPT35=0.002
COST_CLAUDE_SONNET=0.003
COST_CLAUDE_HAIKU=0.00025
